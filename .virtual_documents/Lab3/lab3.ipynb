from scipy.integrate import solve_ivp
import matplotlib.pyplot as plt

g = 9.81
x0 = 4000
v0 = 0
t_eval = np.linspace(0,30, 1000)

def derivatives(t, y):
    dxdt = y[1]
    dvdt = -g
    return dxdt,dvdt

soln = solve_ivp(derivatives, (0, 30), [x0, v0], t_eval = t_eval)

fig, ax = plt.subplots()
ax2 = ax.twinx()
ax.plot(soln.t, soln.y[0], label = "Position")
ax.hlines(0, 0, 30, linestyles=":", color = "orange", label = "X=0")
ax2.plot(soln.t, soln.y[1], color = "red", label = "Velocity")
fig.legend()
fig.tight_layout()
ax.set_title("Figure 1")
ax.set_xlabel("Time (s)")
ax.set_ylabel("Position (m)")
ax2.set_ylabel("Velocity (m/s)")


def hit_bottom(t,y):
    return y[0]

soln = solve_ivp(derivatives, (0, 30), [x0, v0], t_eval = t_eval, events = hit_bottom)

print(f"Time when object hits bottom: {soln.t_events[0][0]:.5f} s")











