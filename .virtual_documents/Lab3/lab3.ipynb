alpha = 0
omega = 7.272E-5

def derivatives(t, s):
    y = s[0]
    dydt = s[1]
    x = s[2]
    dxdt = s[3]
    dvydt = -g*(y/R_E) + alpha*(dydt)**2-2*omega*dxdt
    dvxdt = 2*omega*dydt
    return dydt, dvydt, dxdt, dvxdt

