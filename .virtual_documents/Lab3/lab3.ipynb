G = 6.6743E-11
M_m = 7.35E22
R_m = 1738.1E3

t_eval = np.linspace(0,10000, 2000)

moon_density = M_m/((4/3)*np.pi*R_m**3)

def derivatives(t,y):
    dxdt = y[1]
    dvdt = -G*moon_density*((4/3)*np.pi*y[0]**3)/y[0]**2
    return dxdt,dvdt

def event(t,y):
    return y[0]

soln = solve_ivp(derivatives, (0, 10000), [x0, v0], t_eval = t_eval, events = event)

print(f"Travel time to center of moon: {soln.t_events[0][0]:.2f} s")


