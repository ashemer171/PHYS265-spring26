def density(r,n, pn):
    return pn*(1-r**2/R_E**2)**n

radius = np.linspace(1E-12, R_E, 1000)

fig, ax = plt.subplots()
ax.plot(radius, density(radius,0,1), label = "n=0")
ax.plot(radius, density(radius,1,1), label = "n=1")
ax.plot(radius, density(radius,2,1), label = "n=2")
ax.plot(radius, density(radius,9,1), label = "n=9")
ax.legend()
ax.set_xlabel("Radius (m)")
ax.set_ylabel("Density (kg/m^3)")
ax.set_title("Figure 5")





from scipy.integrate import quad

def normalizationintegral(r, n):
    return density(r,n, 1)*r**2

def pn(n):
    integral, extra = quad(normalizationintegral,0,R_E, args = (n,))
    return M/(4*np.pi*integral)

pns = np.array([pn(0), pn(1), pn(2), pn(9)])

def Mcalc(r, n, pn):
    return 4*np.pi*density(r, n, pn)*r**2

def Mintegral(n, pn):
    Menc = np.zeros_like(radius)
    for i in range(len(Menc)):
        Menc[i], random = quad(Mcalc, 0, radius[i],  args = (n, pn))
    return Menc

F0 = G*Mintegral(0, pns[0])/radius**2
F1 = G*Mintegral(1, pns[1])/radius**2
F2 = G*Mintegral(2, pns[2])/radius**2
F9 = G*Mintegral(9, pns[3])/radius**2

fig, ax = plt.subplots()
ax.plot(radius, F0, label = "n=0")
ax.plot(radius, F1, label = "n=1")
ax.plot(radius, F2, label = "n=2")
ax.plot(radius, F9, label = "n=9")
ax.legend()
ax.set_xlabel("Radius (m)")
ax.set_ylabel("Force (N)")
ax.set_title("Figure 6")





from scipy.interpolate import CubicSpline
t_eval = np.linspace(0, 5000, 2000)
F0eqn = CubicSpline(radius, F0)
F1eqn = CubicSpline(radius, F1)
F2eqn = CubicSpline(radius, F2)
F9eqn = CubicSpline(radius, F9)

def derivatives0(t, y):
    dxdt = y[1]
    dvdt = -F0eqn(np.abs(y[0]))* np.sign(y[0])
    return dxdt,dvdt

def derivatives1(t, y):
    dxdt = y[1]
    dvdt = -F1eqn(np.abs(y[0]))* np.sign(y[0])
    return dxdt,dvdt

def derivatives2(t, y):
    dxdt = y[1]
    dvdt = -F2eqn(np.abs(y[0]))* np.sign(y[0])
    return dxdt,dvdt

def derivatives9(t, y):
    dxdt = y[1]
    dvdt = -F9eqn(np.abs(y[0]))* np.sign(y[0])
    return dxdt,dvdt
def event(t,y):
    return y[0]
soln0 = solve_ivp(derivatives0, (0, 5000), [x0, v0], t_eval = t_eval, events=event)
soln1 = solve_ivp(derivatives1, (0, 5000), [x0, v0], t_eval = t_eval, events=event)
soln2 = solve_ivp(derivatives2, (0, 5000), [x0, v0], t_eval = t_eval, events=event)
soln9 = solve_ivp(derivatives9, (0, 5000), [x0, v0], t_eval = t_eval, events=event)

fig, ax = plt.subplots(2,2)

ax[0,0].plot(soln0.t, soln0.y[0], label = "Position")
ax[0,1].plot(soln1.t, soln1.y[0])
ax[1,0].plot(soln2.t, soln2.y[0])
